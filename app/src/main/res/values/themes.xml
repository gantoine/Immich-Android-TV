<resources>
    <!-- The Leanback theme is available at https://cs.android.com/androidx/platform/frameworks/support/+/androidx-master-dev:leanback/src/main/res/values/themes.xml -->

    <!-- Base application theme. Theme.AppCompat.Leanback (from leanback 1.1.0-rc01) supplies the
         AppCompat color attributes that the leanback preference item TextViews resolve against. -->
    <style name="AppTheme" parent="@style/Theme.AppCompat.Leanback">
        <item name="android:windowBackground">@color/gray_dark</item>
        <item name="android:textColor">@color/default_text_color</item>
        <item name="android:textColorPrimary">@color/default_text_color</item>
        <item name="android:textColorSecondary">@color/default_text_color_secondary</item>
        <item name="android:textColorTertiary">@color/default_text_color_secondary</item>
        <item name="android:textColorTertiaryInverse">@color/default_text_color_secondary</item>
        <!-- Preference fragments inflate in their own ?attr/preferenceTheme context (not AppTheme),
             so the colors above don't reach them. Point preferenceTheme at our overlay below. -->
        <item name="preferenceTheme">@style/AppLeanbackPreferenceTheme</item>
    </style>

    <!-- Overrides leanback's PreferenceThemeOverlayLeanback, which sets
         android:textColorTertiary to ?android:attr/colorAccent (an API 21+ attribute). On API 19
         that reference is unresolvable, so a preference category/title TextView reading
         ?android:attr/textColorTertiary crashes in loadColorStateList. Pin it to a concrete color. -->
    <style name="AppLeanbackPreferenceTheme" parent="@style/PreferenceThemeOverlayLeanback">
        <item name="android:textColorTertiary">@color/default_text_color_secondary</item>
    </style>

    <!-- Theme for card views that show a Video -->
    <style name="VideoCardViewTheme">
        <item name="imageCardViewStyle">@style/CardViewStyle</item>
        <item name="imageCardViewInfoAreaStyle">@style/CardViewInfoAreaStyle</item>
    </style>
</resources>
