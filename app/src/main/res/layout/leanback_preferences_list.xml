<?xml version="1.0" encoding="utf-8"?>
<!--
  Overrides androidx.leanback.preference's leanback_preferences_list.xml.

  On Android 4.4 (API 19) the View constructor runs initializeScrollbars ->
  resolvePadding -> onRtlPropertiesChanged during super-construction, and leanback's
  BaseGridView.onRtlPropertiesChanged dereferences its layout manager before it is
  initialized, throwing a NullPointerException (the preferenceFragmentListStyle sets
  android:scrollbars="vertical"). Setting android:scrollbars="none" directly here
  overrides the style value so initializeScrollbars is never called. On API 21+ this
  resolution is deferred, so the upstream layout works there. Scrollbars are unused on
  a D-pad TV list anyway.

  Do NOT add android:transitionGroup (API 21+) here: AAPT2 would auto-version this file
  into a -v21 variant, so API 19 would fall back to the library's default (scrollbars on)
  and crash again. Keeping this attribute-set API-19-clean makes it the default variant.
-->
<androidx.leanback.widget.VerticalGridView
    android:id="@+id/list"
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:scrollbars="none"
    style="?attr/preferenceFragmentListStyle" />
